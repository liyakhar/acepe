{
	"name": "website",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --open",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "biome format --write .",
		"lint": "biome check .",
		"export:pitch:pdf": "bun run scripts/export-pitch-pdf.ts",
		"test:unit": "vitest",
		"test": "bun run test:unit -- --run",
		"export:pitch-pdf": "node ./scripts/export-pitch-pdf.js",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:seed": "bun run scripts/seed.ts",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@acepe/agent-panel-contract": "workspace:*",
		"@acepe/changelog": "workspace:*",
		"@acepe/ui": "workspace:*",
		"@aws-sdk/client-s3": "^3.700.0",
		"@aws-sdk/s3-request-presigner": "^3.700.0",
		"@paper-design/shaders": "^0.0.68",
		"bits-ui": "^2.14.4",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.36.0",
		"nanoid": "^5.0.0",
		"neverthrow": "^8.2.0",
		"phosphor-svelte": "^3.1.0",
		"pino": "^10.1.0",
		"postgres": "^3.4.5",
		"shiki": "^3.22.0",
		"tailwind-merge": "^3.4.0",
		"tw-animate-css": "^1.4.0",
		"vaul-svelte": "^1.0.0-next.7"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@lucide/svelte": "^0.562.0",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.17",
		"@types/node": "^24",
		"drizzle-kit": "^0.28.0",
		"playwright": "^1.57.0",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.17",
		"typescript": "^5.9.3",
		"vite": "^7.2.6",
		"vitest": "^4.0.15",
		"vitest-browser-svelte": "^2.0.1"
	}
}
