{
	"name": "acepe-tauri",
	"version": "0.1.0",
	"description": "",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"i18n:generate": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && bunx svelte-kit sync",
		"build": "NODE_OPTIONS='--max-old-space-size=8192' vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && tsgo --noEmit -p ./tsconfig.fast.json",
		"check:fast": "svelte-kit sync && tsgo --noEmit -p ./tsconfig.fast.json",
		"check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.svelte-check.json",
		"check:tauri-invokes": "bun run scripts/check-static-tauri-invokes.ts",
		"typecheck": "svelte-kit sync && tsgo --noEmit -p ./tsconfig.fast.json",
		"test": "bun run check:tauri-invokes && bun ../../scripts/forbid-structural-tests.ts src && AGENT=1 bun test $(find src -type f \\( -name '*.test.ts' -o -name '*.vitest.ts' \\))",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage",
		"test:vitest": "bun run check:tauri-invokes && bun ../../scripts/forbid-structural-tests.ts src && vitest run",
		"test:vitest:watch": "vitest",
		"test:rust:fast": "cd src-tauri && cargo test --lib -- --skip claude_history::export_types",
		"test:rust:manual": "cd src-tauri && cargo test --features manual-test-targets --test startup_scan_benchmark && cargo test --features manual-test-targets --test indexer_benchmark && cargo test --features manual-test-targets --test codex_scanner_benchmark && cargo test --features manual-test-targets --test codex_scanner_test && cargo test --features manual-test-targets --test voice_transcription && cargo test --features manual-test-targets --test acp_session_list_probe",
		"tauri": "TAURI_CLI_WATCHER_IGNORE_FILENAME=.taurignore env -u RUSTC_WRAPPER -u CARGO_BUILD_RUSTC_WRAPPER tauri dev",
		"translate:validate": "inlang validate",
		"translate:all": "inlang machine translate --force",
		"translate:update": "inlang machine translate --force",
		"format": "biome format --write .",
		"format:check": "biome check .",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"storage:prune": "bash scripts/prune-storage.sh",
		"audit:session-timing": "bun run scripts/audit-session-timing.ts"
	},
	"license": "FSL-1.1-ALv2",
	"repository": {
		"type": "git",
		"url": "https://github.com/flazouh/acepe.git",
		"directory": "packages/desktop"
	},
	"dependencies": {
		"@acepe/agent-panel-contract": "workspace:*",
		"@acepe/changelog": "workspace:*",
		"@acepe/ui": "workspace:*",
		"@codemirror/autocomplete": "^6.20.0",
		"@codemirror/commands": "^6.10.1",
		"@codemirror/language": "^6.12.1",
		"@codemirror/language-data": "^6.5.2",
		"@codemirror/state": "^6.5.4",
		"@codemirror/view": "^6.39.11",
		"@inlang/paraglide-js": "^2.6.0",
		"@lezer/highlight": "^1.2.3",
		"@lucide/svelte": "^0.562.0",
		"@opencode-ai/sdk": "^1.1.13",
		"@paper-design/shaders": "^0.0.68",
		"@pierre/diffs": "1.1.3",
		"@replit/codemirror-lang-svelte": "^6.0.0",
		"@shikijs/markdown-it": "^3.20.0",
		"@tabler/icons-svelte": "^3.36.0",
		"@tanstack/svelte-virtual": "^3.13.19",
		"@tauri-apps/api": "^2",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.2",
		"@tauri-apps/plugin-opener": "^2",
		"@tauri-apps/plugin-process": "^2.3.1",
		"@tauri-apps/plugin-updater": "2.5.1",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-web-links": "^0.12.0",
		"beautiful-mermaid": "^0.1.3",
		"clsx": "^2.1.1",
		"codemirror": "^6.0.2",
		"lru-cache": "^11.2.4",
		"markdown-it": "^14.1.0",
		"mermaid": "^11.12.2",
		"neverthrow": "^8.2.0",
		"phosphor-svelte": "^3.1.0",
		"tailwind-merge": "^3.4.0",
		"tauri-pty": "^0.2.1",
		"tinykeys": "^3.0.0",
		"virtua": "^0.48.5",
		"xstate": "^5.25.0",
		"xterm": "^5.3.0",
		"yaml": "^2.8.2",
		"zod": "^4.2.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@happy-dom/global-registrator": "^20.1.0",
		"@inlang/cli": "^3.0.12",
		"@internationalized/date": "^3.10.0",
		"@sveltejs/adapter-static": "^3.0.6",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/table-core": "^8.21.3",
		"@tauri-apps/cli": "^2",
		"@testing-library/svelte": "^5.3.1",
		"@types/markdown-it": "^14.1.2",
		"@typescript/native-preview": "^7.0.0-dev.20260319.1",
		"@vitest/browser-playwright": "^4.0.16",
		"@vitest/coverage-v8": "^4.0.16",
		"autoprefixer": "^10.4.27",
		"bits-ui": "^2.14.4",
		"bun-types": "^1.3.5",
		"diff": "^8.0.3",
		"embla-carousel-svelte": "^8.6.0",
		"layerchart": "2.0.0-next.43",
		"mode-watcher": "^1.1.0",
		"playwright": "^1.57.0",
		"shiki": "^3.22.0",
		"svelte": "^5.45.6",
		"svelte-check": "^4.0.0",
		"svelte-sonner": "^1.0.7",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^7.2.6",
		"vitest": "^4.0.16"
	}
}
