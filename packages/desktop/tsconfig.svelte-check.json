{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"checkJs": false
	},
	"include": [
		"ambient.d.ts",
		"non-ambient.d.ts",
		".svelte-kit/types/**/$types.d.ts",
		"src/**/*.d.ts",
		"src/**/*.ts",
		"src/**/*.svelte"
	],
	"exclude": [
		"node_modules/**",
		"src/service-worker.js",
		"src/service-worker/**/*.js",
		"src/service-worker.ts",
		"src/service-worker/**/*.ts",
		"src/service-worker.d.ts",
		"src/service-worker/**/*.d.ts"
	]
}
